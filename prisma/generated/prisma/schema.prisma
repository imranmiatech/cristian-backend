model Company {
  id             String        @id @default(uuid())
  name           String
  email          String
  PhoneNumber    String
  logo           String?
  tags           String[]
  status         CompanyStatus @default(ACTIVE)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  assignUsername String?
  userId         String
  contactName    String?
  user           User          @relation(fields: [userId], references: [id])
  notes          Note[]
}

enum CompanyStatus {
  ACTIVE
  PENDING
}

model Note {
  id               String            @id @default(uuid())
  title            String?
  content          String?
  companyId        String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  isPinned         Boolean           @default(false)
  authorId         String?
  type             String?           @default("GENERAL")
  deletedAt        DateTime?
  parentId         String?
  contactName      String?
  documents        Attachment[]
  author           User?             @relation(fields: [authorId], references: [id])
  company          Company           @relation(fields: [companyId], references: [id])
  parent           Note?             @relation("FollowUps", fields: [parentId], references: [id])
  followUps        Note[]            @relation("FollowUps")
  history          NoteHistory[]
  interactionTypes InteractionType[] @relation("NoteInteractions")
  services         Service[]         @relation("NoteServices")

  @@index([companyId, deletedAt])
  @@index([parentId])
  @@index([authorId])
  @@index([type])
  @@index([createdAt])
}

model NoteHistory {
  id                  String   @id @default(uuid())
  noteId              String
  oldTitle            String?
  oldContent          String?
  changedById         String
  createdAt           DateTime @default(now())
  action              String
  oldDocuments        Json?
  oldInteractionTypes Json?
  oldServices         Json?
  newContactName      String?
  newContent          String?
  newDocuments        Json?
  newInteractionTypes Json?
  newIsPinned         Boolean?
  newServices         Json?
  newTitle            String?
  newType             String?
  oldContactName      String?
  oldIsPinned         Boolean?
  oldType             String?
  changedBy           User     @relation(fields: [changedById], references: [id])
  note                Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
}

model Attachment {
  id        String   @id @default(uuid())
  fileName  String?
  fileUrl   String
  fileType  String?
  fileSize  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  noteId    String?
  note      Note?    @relation(fields: [noteId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id         String    @id @default(uuid())
  jti        String    @unique
  tokenHash  String
  userId     String
  deviceId   String?
  userAgent  String?
  ipAddress  String?
  lastUsedAt DateTime? @default(now())
  expiresAt  DateTime
  isRevoked  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, deviceId, isRevoked])
}

generator client {
  provider      = "prisma-client-js"
  output        = "../generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
  moduleFormat  = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Service {
  id    String @id @default(uuid())
  name  String @unique
  notes Note[] @relation("NoteServices")
}

model InteractionType {
  id    String @id @default(uuid())
  name  String @unique
  notes Note[] @relation("NoteInteractions")
}

model Tag {
  id   String @id @default(uuid())
  name String @unique
}

model User {
  id                  String         @id @default(uuid())
  email               String         @unique
  name                String
  password            String
  mobile              String?
  profile             String?
  role                UserRole
  status              UserStatus     @default(PENDING)
  failedLoginAttempts Int            @default(0)
  lastFailedAttempt   DateTime?
  lockUntil           DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  deletedAt           DateTime?
  company             Company[]
  notes               Note[]
  noteHistories       NoteHistory[]
  refreshTokens       RefreshToken[]

  @@index([email, status, deletedAt])
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DELETED
}

enum UserRole {
  ADMIN
  SUPER_ADMIN
}
