
model User {
  id       String @id @default(uuid())
  email    String @unique
  name     String
  password String
  mobile  String?
  profile String?

  role    UserRole
  status   UserStatus @default(PENDING)
  refreshTokens RefreshToken[]

  failedLoginAttempts Int       @default(0)
  lastFailedAttempt   DateTime?
  lockUntil           DateTime?


  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([email, status, deletedAt])
}


enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DELETED
}

enum UserRole {
  ADMIN
  SUPER_ADMIN
}
