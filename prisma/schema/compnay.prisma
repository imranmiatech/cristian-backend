model Company {
  id             String   @id @default(uuid())
  name           String
  email          String
  PhoneNumber    String
  contactName    String?
  logo           String?
  tags           String[]
  assignUsername String?

  status CompanyStatus @default(ACTIVE)

  notes    Note[]



  userId String
  user   User @relation(fields: [userId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum CompanyStatus {
  ACTIVE
  PENDING
}
