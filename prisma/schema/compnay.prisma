model Company {
  id             String        @id @default(uuid())
  name           String
  email          String
  PhoneNumber    String
  logo           String?
  tags           String[]
  status         CompanyStatus @default(ACTIVE)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  assignUsername String?
  userId         String
  contactName    String?
  user           User          @relation(fields: [userId], references: [id])
  notes          Note[]
}

enum CompanyStatus {
  ACTIVE
  PENDING
}
