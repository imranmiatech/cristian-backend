model Note {
  id               String            @id @default(uuid())
  title            String?
  content          String?
  companyId        String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  isPinned         Boolean           @default(false)
  authorId         String?
  type             String?           @default("GENERAL")
  deletedAt        DateTime?
  parentId         String?
  contactName      String?
  documents        Attachment[]
  author           User?             @relation(fields: [authorId], references: [id])
  company          Company           @relation(fields: [companyId], references: [id])
  parent           Note?             @relation("FollowUps", fields: [parentId], references: [id])
  followUps        Note[]            @relation("FollowUps")
  history          NoteHistory[]
  interactionTypes InteractionType[] @relation("NoteInteractions")
  services         Service[]         @relation("NoteServices")

  @@index([companyId, deletedAt])
  @@index([parentId])
  @@index([authorId])
  @@index([type])
  @@index([createdAt])
}

model NoteHistory {
  id                  String   @id @default(uuid())
  noteId              String
  oldTitle            String?
  oldContent          String?
  changedById         String
  createdAt           DateTime @default(now())
  action              String
  oldDocuments        Json?
  oldInteractionTypes Json?
  oldServices         Json?
  newContactName      String?
  newContent          String?
  newDocuments        Json?
  newInteractionTypes Json?
  newIsPinned         Boolean?
  newServices         Json?
  newTitle            String?
  newType             String?
  oldContactName      String?
  oldIsPinned         Boolean?
  oldType             String?
  changedBy           User     @relation(fields: [changedById], references: [id])
  note                Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
}

model Attachment {
  id        String   @id @default(uuid())
  fileName  String?
  fileUrl   String
  fileType  String?
  fileSize  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  noteId    String?
  note      Note?    @relation(fields: [noteId], references: [id], onDelete: Cascade)
}
